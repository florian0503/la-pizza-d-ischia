{% extends 'base.html.twig' %}

{% block title %}Contact — La Pizza d'Ischia{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/contact.css') }}">
{% endblock %}

{% block body %}

    {# ══════════════════════════════════════════════════════════
       HERO
    ══════════════════════════════════════════════════════════ #}
    <section class="contact-hero">
        <div class="contact-hero-inner fade-up">
            <nav class="contact-breadcrumb" aria-label="Fil d'Ariane">
                <a href="{{ path('app_home') }}">Accueil</a>
                <span aria-hidden="true">›</span>
                <span>Contact</span>
            </nav>
            <span class="contact-eyebrow">— Contattaci</span>
            <h1 class="contact-hero-title">
                Une question&nbsp;?<br><em>On vous répond.</em>
            </h1>
            <p class="contact-hero-sub">
                Vous avez une question sur notre carte, nos horaires ou nos ingrédients&nbsp;?<br>
                Écrivez-nous, nous répondons sous 24&nbsp;h.
            </p>
        </div>
        <div class="contact-tristrip" aria-hidden="true">
            <div class="ts-g"></div>
            <div class="ts-w"></div>
            <div class="ts-r"></div>
        </div>
    </section>

    {# ══════════════════════════════════════════════════════════
       BODY — formulaire + infos
    ══════════════════════════════════════════════════════════ #}
    <section class="contact-body">
        <div class="contact-body-inner">

            {# ── Formulaire ── #}
            <div class="contact-form-wrap fade-up">
                <span class="contact-form-label">Formulaire de contact</span>
                <h2 class="contact-form-title">Posez-nous<br>votre question</h2>
                <div class="contact-form-sep" aria-hidden="true"></div>

                <form class="contact-form" action="#" method="post" novalidate>

                    <div class="contact-form-row">
                        <div class="contact-field">
                            <label for="nom">Nom <span class="contact-required">*</span></label>
                            <input type="text" id="nom" name="nom" placeholder="Votre nom" required>
                        </div>
                        <div class="contact-field">
                            <label for="prenom">Prénom <span class="contact-required">*</span></label>
                            <input type="text" id="prenom" name="prenom" placeholder="Votre prénom" required>
                        </div>
                    </div>

                    <div class="contact-field">
                        <label for="email">Email <span class="contact-required">*</span></label>
                        <input type="email" id="email" name="email" placeholder="votre@email.com" required>
                    </div>

                    <div class="contact-field">
                        <label for="telephone">Téléphone</label>
                        <input type="tel" id="telephone" name="telephone" placeholder="+33 6 00 00 00 00">
                    </div>

                    <div class="contact-field">
                        <label for="message">Message <span class="contact-required">*</span></label>
                        <textarea id="message" name="message" rows="5" placeholder="Votre question sur la carte, les allergènes, les horaires…" required></textarea>
                    </div>

                    <div class="contact-form-footer">
                        <label class="contact-check">
                            <input type="checkbox" name="rgpd" required>
                            <span>J'accepte que mes données soient utilisées pour traiter ma demande, conformément à la politique de confidentialité.</span>
                        </label>
                        <button type="submit" class="contact-submit">
                            Envoyer ma question <span aria-hidden="true">→</span>
                        </button>
                        <p class="contact-required-note">* Champs obligatoires</p>
                    </div>

                </form>
            </div>

            {# ── Infos + réseaux ── #}
            <div class="contact-aside">

                <div class="contact-info-card fade-up">
                    <h3 class="contact-info-title">Informations de contact</h3>
                    <p class="contact-info-sub">Vous préférez nous appeler directement&nbsp;? Nous sommes disponibles du mardi au dimanche.</p>
                    <div class="contact-info-sep" aria-hidden="true"></div>

                    <ul class="contact-info-list">
                        <li class="contact-info-item">
                            <span class="contact-info-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                            </span>
                            <div>
                                <span class="contact-info-key">Email</span>
                                <span class="contact-info-val">contact@lapizzadischia.fr</span>
                            </div>
                        </li>
                        <li class="contact-info-item">
                            <span class="contact-info-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                            </span>
                            <div>
                                <span class="contact-info-key">Téléphone</span>
                                <span class="contact-info-val">+33 4 XX XX XX XX</span>
                            </div>
                        </li>
                        <li class="contact-info-item">
                            <span class="contact-info-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                            </span>
                            <div>
                                <span class="contact-info-key">Horaires</span>
                                <span class="contact-info-val">Mar–Ven&nbsp;: 12h–14h30 · 19h–22h30<br>Sam–Dim&nbsp;: 12h–15h · 19h–23h<br><em>Lundi fermé</em></span>
                            </div>
                        </li>
                        <li class="contact-info-item">
                            <span class="contact-info-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                            </span>
                            <div>
                                <span class="contact-info-key">Adresse</span>
                                <span class="contact-info-val">12 Rue de la Paix<br>Messimy, Ain — France</span>
                            </div>
                        </li>
                    </ul>
                </div>

                <div class="contact-social-card fade-up">
                    <span class="contact-social-label">Suivez-nous</span>
                    <div class="contact-social-links">
                        <a href="#" class="contact-social-btn" aria-label="Instagram">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                        </a>
                    </div>
                </div>

            </div>

        </div>
    </section>

{% endblock %}
