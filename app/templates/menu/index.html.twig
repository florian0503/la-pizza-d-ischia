{% block javascripts %}
    {{ parent() }}
    <script type="module" src="{{ asset('home.js') }}"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const tabs = document.querySelectorAll('.menu-tab');
            const tabsBar = document.querySelector('.menu-tabs');
            const sectionIds = ['antipasti', 'rosse', 'bianche', 'speciali', 'dolci', 'vini'];
            const sections = sectionIds.map(id => document.getElementById(id)).filter(Boolean);

            function getOffset() {
                const header = document.getElementById('site-header');
                return (header ? header.offsetHeight : 72) + (tabsBar ? tabsBar.offsetHeight : 44) + 8;
            }

            tabs.forEach(function (t) {
                t.addEventListener('click', function () {
                    const el = document.getElementById(t.dataset.tab);
                    if (el) {
                        const top = el.getBoundingClientRect().top + window.scrollY - getOffset();
                        window.scrollTo({ top: top, behavior: 'smooth' });
                    }
                });
            });

            window.addEventListener('scroll', function () {
                const offset = getOffset();
                const sy = window.scrollY + offset + 32;
                let active = sections[0] ? sections[0].id : null;
                sections.forEach(function (s) {
                    if (s.offsetTop <= sy) { active = s.id; }
                });
                tabs.forEach(function (t) {
                    t.classList.toggle('active', t.dataset.tab === active);
                });
            }, { passive: true });
        });
    </script>
{% endblock %}
