                <li class="menu-item" style="--i:2">
                    <span class="menu-num">03</span>
                    <div class="menu-info">
                        <span class="menu-name">Carpaccio di <em>Manzo</em></span>
                        <span class="menu-ingredients">Bœuf cru tranché fin · Copeaux de parmigiano 24 mois · Roquette · Citron</span>
                    </div>
                    <span class="menu-price">15 <small>€</small></span>
                </li>

                <li class="menu-item" style="--i:3">
                    <span class="menu-num">04</span>
                    <div class="menu-info">
                        <span class="menu-name">Polpette <em>della Nonna</em></span>
                        <span class="menu-ingredients">Boulettes bœuf et porc · Sauce tomate maison · Parmigiano · Pain grillé</span>
                    </div>
                    <span class="menu-price">11 <small>€</small></span>
                </li>

                <li class="menu-item" style="--i:4">
                    <span class="menu-num">05</span>
                    <div class="menu-info">
                        <span class="menu-name">
                            Verdure <em>grigliate</em>
                            <span class="tag tag-veggie" aria-label="Végétarien">Veg</span>
                        </span>
                        <span class="menu-ingredients">Aubergines · Courgettes · Poivrons grillés · Ricotta fumée · Pignons</span>
                    </div>
                    <span class="menu-price">10 <small>€</small></span>
