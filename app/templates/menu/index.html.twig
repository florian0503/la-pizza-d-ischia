            </div>

            <ol class="menu-list stagger">

                <li class="menu-item" style="--i:0">
                    <span class="menu-num">01</span>
                    <div class="menu-info">
                        <span class="menu-name">
                            Burrata <em>delle Puglie</em>
                            <span class="tag tag-veggie" aria-label="Végétarien">Veg</span>
                        </span>
                        <span class="menu-ingredients">Burrata des Pouilles · Tomates anciennes · Basilic · Huile d'olive de Sorrente · Fleur de sel</span>
                    </div>
                    <span class="menu-price">12 <small>€</small></span>
                </li>

                <li class="menu-item" style="--i:1">
                    <span class="menu-num">02</span>
                    <div class="menu-info">
                        <span class="menu-name">Vitello <em>Tonnato</em></span>
