{% extends 'base.html.twig' %}

{% block title %}La Carte — La Pizza d'Ischia{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/home.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/menu.css') }}">
{% endblock %}

{% block body %}

    {# ══════════════════════════════════════════════════════════
       1. HERO
    ══════════════════════════════════════════════════════════ #}
    <section class="menu-hero">

        <div class="menu-hero-topbar">
            <span class="menu-hero-topbar-item">La Carte &mdash; Hiver 2026</span>
            <span class="menu-hero-topbar-item">21 références &middot; Pétries chaque matin</span>
            <span class="menu-hero-topbar-item">Édition n°XII</span>
        </div>

        <div class="menu-hero-main">
            <h1 class="menu-hero-h1 reveal-text" data-split>
                Notre<br><em>carta.</em>
            </h1>
            <div class="menu-hero-sub">
                <p class="menu-hero-sub-left fade-up">
                    <em>« Une carte courte, qui change avec les saisons. Pizzas napolitaines, antipasti, dolci — et ce qu'on a trouvé ce matin au marché. »</em>
                </p>
                <p class="menu-hero-sub-right fade-up">
                    Tous nos prix en euros, taxes incluses.<br>
                    Pizzas 30&nbsp;cm &middot; Pâte 72&nbsp;h.<br>
                    Sans gluten sur demande (+2€).
                </p>
            </div>
        </div>

    </section>

    {# ══════════════════════════════════════════════════════════
       2. LÉGENDE
    ══════════════════════════════════════════════════════════ #}
    <div class="menu-legende fade-up">
        <span class="menu-legende-title"><em>— Légende</em></span>
        <div class="menu-legende-items">
            <span class="menu-legende-item">
                <span class="menu-tag tag-veggie" aria-hidden="true"></span>
                <span>Végétarien</span>
            </span>
            <span class="menu-legende-item">
                <span class="menu-tag tag-spicy" aria-hidden="true"></span>
                <span>Piquant</span>
            </span>
            <span class="menu-legende-item">
                <span class="menu-tag tag-new" aria-hidden="true"></span>
                <span>Nouveauté</span>
            </span>
            <span class="menu-legende-item">
                <span class="menu-tag tag-signature" aria-hidden="true"></span>
                <span>Signature</span>
            </span>
        </div>
    </div>

    {# ══════════════════════════════════════════════════════════
       3. TABS STICKY
    ══════════════════════════════════════════════════════════ #}
    <nav class="menu-tabs" aria-label="Sections du menu">
        <button class="menu-tab active" data-tab="antipasti">Antipasti</button>
        <button class="menu-tab" data-tab="rosse">Pizzas Rosse</button>
        <button class="menu-tab" data-tab="bianche">Pizzas Bianche</button>
        <button class="menu-tab" data-tab="speciali">Speciali</button>
        <button class="menu-tab" data-tab="dolci">Dolci</button>
        <button class="menu-tab" data-tab="vini">Vini &amp; Boissons</button>
    </nav>

    {# ══════════════════════════════════════════════════════════
       4. ANTIPASTI
    ══════════════════════════════════════════════════════════ #}
