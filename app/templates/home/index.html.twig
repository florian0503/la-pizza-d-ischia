        <div class="selection-inner">

            <div class="selection-header fade-up">
                <div class="selection-header-text">
                    <span class="eyebrow">N°02 — La selezione dello chef</span>
                    <h2 class="selection-title">Quelques <em>classiques</em>,<br>cuits comme à la maison.</h2>
                </div>
                <div class="selection-header-img" aria-hidden="true">
                    <img src="https://images.unsplash.com/photo-1571407970349-bc81e7e96d47?w=400&q=80" alt="" loading="lazy">
                </div>
            </div>

            <ol class="menu-list stagger">

                <li class="menu-item" style="--i:0">
                    <span class="menu-num">N°01</span>
                    <div class="menu-info">
                        <span class="menu-name">Margherita <em>Vera</em></span>
                        <span class="menu-ingredients">San Marzano D.O.P. · Mozzarella di Bufala · Basilic · Huile d'olive</span>
                    </div>
                    <span class="menu-price">14 €</span>
                </li>

                <li class="menu-item" style="--i:1">
                    <span class="menu-num">N°02</span>
                    <div class="menu-info">
                        <span class="menu-name">Diavola <em>Calabraise</em></span>
                        <span class="menu-ingredients">Tomate · Salami piccante · Piment calabrais · Mozzarella</span>
                    </div>
                    <span class="menu-price">17 €</span>
                </li>

                <li class="menu-item" style="--i:2">
                    <span class="menu-num">N°03</span>
                    <div class="menu-info">
                        <span class="menu-name"><em>Marinara</em></span>
                        <span class="menu-ingredients">Tomate San Marzano · Ail · Origan · Huile d'olive</span>
                    </div>
                    <span class="menu-price">11 €</span>
                </li>

                <li class="menu-item" style="--i:3">
                    <span class="menu-num">N°04</span>
                    <div class="menu-info">
                        <span class="menu-name">Tartufo <em>Nero</em></span>
                        <span class="menu-ingredients">Crème de truffe noire · Mozzarella fior di latte · Parmesan 24 mois</span>
                    </div>
                    <span class="menu-price">22 €</span>
                </li>

                <li class="menu-item" style="--i:4">
                    <span class="menu-num">N°05</span>
                    <div class="menu-info">
                        <span class="menu-name">Quattro <em>Formaggi</em></span>
                        <span class="menu-ingredients">Mozzarella · Gorgonzola · Pecorino Romano · Parmesan</span>
