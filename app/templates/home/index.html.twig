{% extends 'base.html.twig' %}

{% block title %}La Pizza d'Ischia — Accueil{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/home.css') }}">
{% endblock %}

{% block body %}

    {# ══════════════════════════════════════════════════════════
       1. HERO CINÉMATIQUE
    ══════════════════════════════════════════════════════════ #}
    <section class="hero" aria-label="La Pizza d'Ischia">

        {# Ken Burns frames #}
        <div class="hero-bg" aria-hidden="true">
            <div class="hero-frame hero-frame--1">
                <img src="https://images.unsplash.com/photo-1574071318508-1cdbab80d002?w=1600&q=80" alt="">
            </div>
            <div class="hero-frame hero-frame--2">
                <img src="https://images.unsplash.com/photo-1555396273-367ea4eb4db5?w=1600&q=80" alt="">
            </div>
            <div class="hero-frame hero-frame--3">
                <img src="https://images.unsplash.com/photo-1513104890138-7c749659a591?w=1600&q=80" alt="">
            </div>
            <div class="hero-frame hero-frame--4">
                <img src="https://images.unsplash.com/photo-1571407970349-bc81e7e96d47?w=1600&q=80" alt="">
            </div>
        </div>

        <div class="hero-overlay" aria-hidden="true"></div>

        {# Film grain #}
        <svg class="hero-grain" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
            <filter id="grain-filter">
                <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/>
                <feColorMatrix type="saturate" values="0"/>
            </filter>
            <rect width="100%" height="100%" filter="url(#grain-filter)"/>
        </svg>

        {# Floating badge #}
        <div class="hero-badge" aria-hidden="true">
            <span class="hero-badge-dal">Dal</span>
            <strong class="hero-badge-year">1962</strong>
            <span class="hero-badge-sub">Tre<br>Generazioni</span>
        </div>

        {# Meta top bar #}
        <div class="hero-top">
            <div class="hero-meta">
                <span class="hero-tristrip" aria-hidden="true">
                    <span class="ts-g"></span>
                    <span class="ts-w"></span>
                    <span class="ts-r"></span>
                </span>
                <span class="hero-meta-text">Napoli × Messimy &mdash; Dal 1962 &middot; Servizio fino alle 23h &middot; Hiver 2026</span>
            </div>
        </div>

        {# H1 main #}
        <div class="hero-content">
            <p class="hero-surtitle">Vera Pizza Napoletana &mdash; Forno a legna</p>
            <h1 class="hero-h1">
                La Pizza<br><em>d'Ischia</em>
            </h1>
        </div>

        {# Footer 3 cols + scroll #}
        <div class="hero-footer">
            <div class="hero-footer-cols">
                <div>
                    <span class="hero-footer-label">— La promesse</span>
                    <p class="hero-footer-text"><em>"La pizza è vita."</em><br>Mangée chaude, au coin d'une table.</p>
                </div>
                <div>
                    <span class="hero-footer-label">— Adresse</span>
                    <p class="hero-footer-text">12 Rue de la Paix<br>Messimy, Ain — France</p>
                </div>
                <div>
                    <span class="hero-footer-label">— Horaires</span>
                    <p class="hero-footer-text">Mar–Ven&nbsp;: 12h–14h30 · 19h–22h30<br>Sam–Dim&nbsp;: 12h–15h · 19h–23h<br><em>Lundi fermé</em></p>
                </div>
            </div>
            <div class="hero-scroll-indicator">
                <span class="hero-scroll-label">Défiler</span>
                <div class="hero-scroll-line" aria-hidden="true"></div>
            </div>
        </div>

    </section>

    {# ══════════════════════════════════════════════════════════
       2. BANDE TRICOLORE
    ══════════════════════════════════════════════════════════ #}
    <div class="tricolor" aria-hidden="true">
        <div class="tricolor-g"></div>
        <div class="tricolor-w"></div>
        <div class="tricolor-r"></div>
    </div>

    {# ══════════════════════════════════════════════════════════
       3. MANIFESTO
    ══════════════════════════════════════════════════════════ #}
    <section class="manifesto" aria-labelledby="manifesto-title">
        <div class="manifesto-left fade-up">
            <span class="manifesto-chapter">— Capitolo I · Manifesto</span>
            <h2 class="manifesto-title" id="manifesto-title">Il nostro<br>credo</h2>
        </div>
        <div class="manifesto-right">
            <p class="manifesto-quote reveal-lines">
                <span class="line"><span class="line-inner">Une pizza n'est pas</span></span>
                <span class="line"><span class="line-inner">un plat. C'est un <em>souvenir</em></span></span>
                <span class="line"><span class="line-inner">qui se mange avec les doigts,</span></span>
                <span class="line"><span class="line-inner">au coin d'une table,</span></span>
                <span class="line"><span class="line-inner">en se <em>brûlant</em> <span class="mute">un peu</span></span></span>
                <span class="line"><span class="line-inner"><span class="mute">la bouche.</span></span></span>
            </p>
        </div>
    </section>

    {# ══════════════════════════════════════════════════════════
       4. MARQUEE 1
    ══════════════════════════════════════════════════════════ #}
    <div class="marquee-band" aria-hidden="true">
        <div class="marquee-track">
            <span class="marquee-word">Forno a legna</span><span class="marquee-dot"></span>
            <span class="marquee-word">Mamma mia</span><span class="marquee-dot"></span>
            <span class="marquee-word">Farina Caputo 00</span><span class="marquee-dot"></span>
            <span class="marquee-word">San Marzano</span><span class="marquee-dot"></span>
            <span class="marquee-word">Mozzarella di Bufala</span><span class="marquee-dot"></span>
            <span class="marquee-word">72 ore di maturazione</span><span class="marquee-dot"></span>
            <span class="marquee-word">Buon appetito</span><span class="marquee-dot"></span>
            <span class="marquee-word">Bellissima</span><span class="marquee-dot"></span>
            <span class="marquee-word">Buongiorno</span><span class="marquee-dot"></span>
            <span class="marquee-word">Forno a legna</span><span class="marquee-dot"></span>
            <span class="marquee-word">Mamma mia</span><span class="marquee-dot"></span>
            <span class="marquee-word">Farina Caputo 00</span><span class="marquee-dot"></span>
            <span class="marquee-word">San Marzano</span><span class="marquee-dot"></span>
            <span class="marquee-word">Mozzarella di Bufala</span><span class="marquee-dot"></span>
            <span class="marquee-word">72 ore di maturazione</span><span class="marquee-dot"></span>
            <span class="marquee-word">Buon appetito</span><span class="marquee-dot"></span>
            <span class="marquee-word">Bellissima</span><span class="marquee-dot"></span>
            <span class="marquee-word">Buongiorno</span><span class="marquee-dot"></span>
        </div>
    </div>

    {# ══════════════════════════════════════════════════════════
       5. STICKY SCROLL — PROCESS
    ══════════════════════════════════════════════════════════ #}
    <section class="process" aria-label="Notre savoir-faire">

        {# Sticky image column #}
        <div class="process-visual" id="processVisual" aria-hidden="true">
            <img class="process-img" id="processImg"
                src="https://images.unsplash.com/photo-1594007654729-407eedc4be65?w=900&q=80"
                alt="La pâte napolitaine">
            <span class="process-roman" id="processRoman"><em>i</em></span>
        </div>

        {# Scrolling panels #}
        <div class="process-panels" id="processPanels">

            <div class="panel">
                <span class="process-eyebrow">N°01 — La Pâte</span>
                <h3 class="process-title">Soixante-douze <em>heures</em> de patience.</h3>
                <p class="process-text">Farine Caputo 00, eau, sel et levain naturel. Trois jours à 4°C, puis deux heures à température ambiante avant de l'étirer à la main. Aucune machine. Aucune précipitation.</p>
            </div>

            <div class="panel">
                <span class="process-eyebrow">N°02 — Le Feu</span>
                <h3 class="process-title">Quatre cents <em>degrés</em>, soixante secondes.</h3>
                <p class="process-text">Notre four à bois date de 1962. Chêne et hêtre secs, allumés chaque matin à l'aube. Il faut quatre heures pour atteindre la bonne chaleur. Il ne s'éteint jamais en service.</p>
            </div>

            <div class="panel">
                <span class="process-eyebrow">N°03 — La Tomate</span>
                <h3 class="process-title">San Marzano, <em>D.O.P.</em> du Vésuve.</h3>
                <p class="process-text">Cultivées sur les flancs du Vésuve, dans un sol volcanique unique. Ni cuite, ni mixée — écrasée à la main avec du sel, de l'huile, quelques feuilles de basilic. C'est tout.</p>
            </div>

            <div class="panel">
                <span class="process-eyebrow">N°04 — Le Service</span>
                <h3 class="process-title">Mangée <em>tout de suite</em> ou pas du tout.</h3>
                <p class="process-text">Une pizza napolitaine ne voyage pas, ne se réchauffe pas, ne s'adapte pas. Elle sort du four, elle arrive sur la table, et elle se mange là, maintenant, pendant qu'elle est encore vivante.</p>
            </div>

        </div>

    </section>

    {# ══════════════════════════════════════════════════════════
       6. MARQUEE 2
    ══════════════════════════════════════════════════════════ #}
    <div class="marquee-band marquee-band--dark" aria-hidden="true">
        <div class="marquee-track">
            <span class="marquee-word">Margherita</span><span class="marquee-dot"></span>
            <span class="marquee-word">Marinara</span><span class="marquee-dot"></span>
            <span class="marquee-word">Diavola</span><span class="marquee-dot"></span>
            <span class="marquee-word">Bufala</span><span class="marquee-dot"></span>
            <span class="marquee-word">Quattro Formaggi</span><span class="marquee-dot"></span>
            <span class="marquee-word">Tartufo</span><span class="marquee-dot"></span>
            <span class="marquee-word">Capricciosa</span><span class="marquee-dot"></span>
            <span class="marquee-word">L'Ischia</span><span class="marquee-dot"></span>
            <span class="marquee-word">Margherita</span><span class="marquee-dot"></span>
            <span class="marquee-word">Marinara</span><span class="marquee-dot"></span>
            <span class="marquee-word">Diavola</span><span class="marquee-dot"></span>
            <span class="marquee-word">Bufala</span><span class="marquee-dot"></span>
            <span class="marquee-word">Quattro Formaggi</span><span class="marquee-dot"></span>
            <span class="marquee-word">Tartufo</span><span class="marquee-dot"></span>
            <span class="marquee-word">Capricciosa</span><span class="marquee-dot"></span>
            <span class="marquee-word">L'Ischia</span><span class="marquee-dot"></span>
        </div>
    </div>

    {# ══════════════════════════════════════════════════════════
       7. SÉLECTION DU CHEF
    ══════════════════════════════════════════════════════════ #}
