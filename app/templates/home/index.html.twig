                <li class="menu-item menu-item--signature" style="--i:5">
                    <span class="menu-num">N°06</span>
                    <div class="menu-info">
                        <span class="menu-name"><em>L'Ischia</em> <span class="menu-badge">La signature</span></span>
                        <span class="menu-ingredients">San Marzano · Bufala · Anchois de Cetara · Câpres · Olives Taggiasca · Basilic</span>
