{% extends 'base.html.twig' %}

{% block title %}Galerie — La Pizza d'Ischia{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/galerie.css') }}">
{% endblock %}

{% block body %}

{# ── Hero ──────────────────────────────────────────────────────── #}
<section class="galerie-hero">
    <div class="galerie-hero-topbar">
        <span class="galerie-hero-topbar-item">— La galerie</span>
        <span class="galerie-hero-topbar-item">18 photos &middot; Pizzas, four, salle &amp; ingrédients</span>
        <span class="galerie-hero-topbar-item">Depuis 2014</span>
    </div>
    <div class="galerie-hero-inner">
        <h1 class="galerie-hero-title">
            La <em>galerie</em><br>d'Ischia.
        </h1>
        <p class="galerie-hero-sub fade-up">
            Nos pizzas, notre four, notre salle et les instants qui font de chaque repas un souvenir.
        </p>
    </div>
</section>

{# ── Filters ───────────────────────────────────────────────────── #}
<div class="galerie-filters">
    <div class="galerie-filters-inner">
        <button class="galerie-filter-btn active" data-filter="all">Tout</button>
        <button class="galerie-filter-btn" data-filter="pizza">Pizzas</button>
        <button class="galerie-filter-btn" data-filter="four">Le four</button>
        <button class="galerie-filter-btn" data-filter="ingrediants">Ingrédients</button>
        <button class="galerie-filter-btn" data-filter="salle">La salle</button>
    </div>
</div>

