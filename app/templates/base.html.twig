<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}La Pizza d'Ischia{% endblock %}</title>
        <link rel="icon" type="image/png" href="{{ asset('images/logo.png') }}">

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,300;1,400;1,600&display=swap" rel="stylesheet">
        <link href="https://db.onlinewebfonts.com/c/bb99de1682ee75602d351c1dde11a054?family=TAN+-+PEARL" rel="stylesheet">
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/layout.css') }}">
        {% endblock %}
        <style>
            * { font-family: "TAN - PEARL", serif !important; }

            .philosophie-heading em {
                padding-right: 0.3em;
            }

            .pizza-card-price,
            .avis-stars,
            .avis-author,
            .localisation-item-label,
            .section-label {
                display: inline-block;
                width: fit-content;
            }

            .section-label,
            .hero-sub,
            .avis-stars,
            .avis-author,
            .localisation-item-label,
            .pizza-card-price,
            .pizza-card-badge,
            .philosophie-heading em,
            .header-nav-link:hover,
            .header-nav-link.active,
            .footer-credit span {
                background: linear-gradient(to right, #00a651 0%, #ffffff 50%, #cc1a16 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

            .hero-sub {
                margin-bottom: 2.5rem;
            }

            .localisation-link {
                background: none;
                -webkit-text-fill-color: #ffffff;
                color: #ffffff;
            }
        </style>

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
            <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
            <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
            <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        {{ include('partials/_header.html.twig') }}
        <div class="scroll-progress" id="scrollProgress" aria-hidden="true"></div>

        <main>
            {% block body %}{% endblock %}
        </main>

        {{ include('partials/_footer.html.twig') }}

        <button class="scroll-top" id="scrollTop" aria-label="Retour en haut" type="button"></button>
    </body>
</html>
